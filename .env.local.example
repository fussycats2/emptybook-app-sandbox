NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 네이버 커스텀 OAuth 콜백에서 admin.createUser / generateLink 호출에 필요
SUPABASE_SERVICE_ROLE_KEY=

# 네이버 도서 검색 API (서버 전용 — NEXT_PUBLIC_ 절대 붙이지 말 것)
# https://developers.naver.com/apps 에서 "검색 API" 권한으로 앱을 만들고 발급
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 네이버 OAuth 로그인 (서버 전용)
# https://developers.naver.com/apps 에서 "네이버 로그인" 권한으로 별도 앱을 만들고 발급
# Callback URL 에 https://<domain>/api/auth/naver/callback 등록 필요
NAVER_OAUTH_CLIENT_ID=
NAVER_OAUTH_CLIENT_SECRET=
